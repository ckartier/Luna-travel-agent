rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══ GLOBAL COLLECTIONS ═══

    // Users: only the owner can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Subscriptions: user can read their own (keyed by email)
    match /subscriptions/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false; // Only Admin SDK / webhooks
    }

    // Platform settings (read-only for maintenance flag)
    match /settings/{document} {
      allow read: if true;
      allow write: if false; // Only Admin SDK
    }

    // ═══ TENANT-SCOPED COLLECTIONS ═══
    // All CRM data lives under tenants/{tenantId}/
    // A user can only access data in their own tenant

    match /tenants/{tenantId} {
      // Tenant document: members can read (or owner by UID), owner can create/update
      allow read: if request.auth != null && (request.auth.uid == tenantId || isTenantMember(tenantId));
      allow create: if request.auth != null && request.auth.uid == tenantId;
      allow update: if request.auth != null && request.auth.uid == tenantId;

      // All sub-collections: authenticated tenant members only
      match /{collection}/{document=**} {
        allow read, write: if request.auth != null && isTenantMember(tenantId);
      }
    }

    // Helper: check if the authenticated user belongs to the tenant
    function isTenantMember(tenantId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }
  }
}
