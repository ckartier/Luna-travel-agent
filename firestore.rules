rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: only the owner can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // CRM collections: any authenticated user
    match /leads/{document} {
      allow read, write: if request.auth != null;
    }
    match /contacts/{document} {
      allow read, write: if request.auth != null;
    }
    match /activities/{document} {
      allow read, write: if request.auth != null;
    }
    match /trips/{document} {
      allow read, write: if request.auth != null;
    }
    // Subscriptions: authenticated user can read their own subscription (keyed by email)
    match /subscriptions/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if false; // Only admin SDK / webhooks can write
    }
    // Platform settings (admin-only via Admin SDK, read for maintenance flag)
    match /settings/{document} {
      allow read: if true;
      allow write: if false;
    }
  }
}
