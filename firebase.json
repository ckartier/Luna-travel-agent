{
    "firestore": {
        "rules": "firestore.rules",
        "indexes": "firestore.indexes.json"
    },
    "storage": {
        "rules": "storage.rules"
    },
    "hosting": {
        "source": ".",
        "frameworksBackend": {
            "memory": "1GiB"
        },
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [],
        "headers": [
            {
                "source": "**/*.@(js|css|jpg|jpeg|gif|png|svg|webp|woff2)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "max-age=31536000, immutable"
                    }
                ]
            }
        ]
    }
}
